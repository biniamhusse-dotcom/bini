<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_sale_order_custom" model="ir.ui.view">
        <field name="name">sale.order.custom.form.inherited</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form" />
        <field name="arch" type="xml">
            <!-- Hide 'validity_date' in its original position -->
            <xpath expr="//field[@name='validity_date']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <!-- Move 'validity_date' after 'provider_name' -->
            <xpath expr="//field[@name='provider_name']" position="after">
                <field name="validity_date" />
            </xpath>

            <!-- Hide 'date_order' in its original position -->
            <xpath expr="//field[@name='shop_id']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <!-- Move 'shop_id' after 'provider_name' -->
            <xpath expr="//field[@name='provider_name']" position="after">
                <field name="shop_id" />
            </xpath>

            <!-- Hide 'partner_village' in its original position -->
            <xpath expr="//field[@name='partner_village']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <!-- Hide 'pricelist_id' in its original position -->
            <xpath expr="//field[@name='pricelist_id']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <xpath expr="//field[@name='payment_term_id']" position="after">
                <field name="payment_method" />
                <button name="action_fetch_payment_info" string="Fetch Payment Info" type="object"
                    class="btn-primary"
                    attrs="{'invisible': [('state', 'not in', ('draft', 'sent'))]}" />
            </xpath>

            <xpath expr="//field[@name='payment_method']" position="after">
                <field name="credit_type"
                    attrs="{'invisible': [('payment_method', '!=', 2)], 
                               'required': [('payment_method', '=', 2)]}" />
            </xpath>

            <xpath expr="//field[@name='credit_type']" position="after">
                <field name="id_number"
                        attrs="{'invisible': [('payment_method', 'in', (1, False))], 
                               'required': [('payment_method', 'in', (2,3,4,5))]}"/>
            </xpath>

            <xpath expr="//field[@name='payment_method']" position="after">
                <field name="free_service"
                    attrs="{'invisible': [('payment_method', '!=', 3)], 
                               'required': [('payment_method', '=', 3)]}" />
            </xpath>

            <xpath expr="//field[@name='credit_type']" position="after">
                <field name="credit_company_name"
                    attrs="{'invisible': ['|', ('credit_type', 'not in', (2,3,4,5)), 
                                                 ('payment_method', '!=', 2)], 
                               'required': [('credit_type', 'in', (2,3,4,5))]}" />
            </xpath>

            <xpath expr="//field[@name='credit_company_name']" position="after">
                <field name="brigade_name"
                    attrs="{'invisible': [('credit_company_name', '!=', 1)], 
                               'required': [('credit_company_name', '=', 1)]}" />
            </xpath>

            <xpath expr="//field[@name='credit_company_name']" position="after">
                <field name="battalion"
                    attrs="{'invisible': [('credit_company_name', '!=', 1)], 
                               'required': [('credit_company_name', '=', 1)]}" />
            </xpath>

            <xpath expr="//field[@name='credit_company_name']" position="after">
                <field name="campus_name"
                    attrs="{'invisible': [('credit_type', '!=', 5)], 
                               'required': [('credit_type', '=', 5)]}" />
            </xpath>

            <xpath expr="//field[@name='credit_company_name']" position="after">
                <field name="working_place"
                    attrs="{'invisible': ['|', ('credit_type', '!=', 4), 
                                                 ('payment_method', '!=', 2)], 
                               'required': [('credit_type', '=', 4)]}" />
            </xpath>

            <xpath expr="//field[@name='credit_type']" position="after">
                <field name="cbhi_woreda_name"
                    attrs="{'invisible': ['|', ('credit_type', '!=', 1), 
                                                 ('payment_method', '!=', 2)], 
                               'required': [('credit_type', '=', 1)]}" />
            </xpath>
            <!-- Insert fields before 'validity_date' -->
            <!-- <xpath expr="//field[@name='provider_name']" position="after">
                <group></group>
            </xpath> -->
        </field>
    </record>
</odoo>